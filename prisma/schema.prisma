generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model University {
  id            String    @id @default(cuid())
  name          String    @unique
  shortName     String    @unique
  slug          String    @unique
  location      String
  isActive      Boolean   @default(true)
  deliveryAreas Json      @default("[]")
  hostels       Json      @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
  users         User[]

  @@index([slug])
  @@index([isActive])
  @@schema("public")
}

model User {
  id                       String              @id @default(cuid())
  phone                    String              @unique
  email                    String?             @unique
  password                 String
  matricNumber             String?             @unique
  name                     String
  profilePhoto             String?
  role                     UserRole            @default(BUYER)
  isSellerMode             Boolean             @default(true)
  hostelName               String?
  roomNumber               String?
  landmark                 String?
  bio                      String?
  trustLevel               TrustLevel          @default(BRONZE)
  avgRating                Float               @default(0)
  totalReviews             Int                 @default(0)
  completedOrders          Int                 @default(0)
  penaltyPoints            Int                 @default(0)
  isSuspended              Boolean             @default(false)
  suspendedUntil           DateTime?
  warningCount             Int                 @default(0)
  lastWarningAt            DateTime?
  pendingBalance           Decimal             @default(0) @db.Decimal(12, 2)
  availableBalance         Decimal             @default(0) @db.Decimal(12, 2)
  isRiderVerified          Boolean             @default(false)
  riderIdDocument          String?
  isAvailable              Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  suspensionReason         String?
  deletedAt                DateTime?
  isDeleted                Boolean             @default(false)
  referralCode             String              @unique
  referredById             String?
  withdrawalPin            String?
  withdrawalPinAttempts    Int                 @default(0)
  withdrawalPinLockedUntil DateTime?
  universityId             String?
  auditLogs                AuditLog[]
  cart                     Cart?
  buyerBatches             DeliveryBatch[]     @relation("BuyerBatches")
  riderBatches             DeliveryBatch[]     @relation("RiderBatches")
  disputesAsBuyer          Dispute[]           @relation("BuyerDisputes")
  resolvedDisputes         Dispute[]           @relation("ResolvedBy")
  disputesAsSeller         Dispute[]           @relation("SellerDisputes")
  notifications            Notification[]
  orders                   Order[]             @relation("BuyerOrders")
  riderDeliveries          Order[]             @relation("RiderDeliveries")
  sellerOrders             Order[]             @relation("SellerOrders")
  issuedPenalties          Penalty[]           @relation("IssuedBy")
  penaltiesReceived        Penalty[]           @relation("UserPenalties")
  products                 Product[]
  productReviewsGiven      ProductReview[]     @relation("ProductReviewsGiven")
  pushSubscriptions        PushSubscription[]
  referralRewardsGenerated ReferralReward[]    @relation("ReferredUserRewards")
  referralRewardsEarned    ReferralReward[]    @relation("ReferrerRewards")
  reportsReceived          Report[]            @relation("ReportsReceived")
  reportsSubmitted         Report[]            @relation("ReportsSubmitted")
  resolvedReports          Report[]            @relation("ResolvedBy")
  reviewsReceived          Review[]            @relation("UserReviewsReceived")
  reviewsGiven             Review[]            @relation("UserReviewsGiven")
  supportTickets           SupportTicket[]
  transactions             Transaction[]
  referredBy               User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals                User[]              @relation("UserReferrals")
  university               University?         @relation(fields: [universityId], references: [id])
  withdrawalRequests       WithdrawalRequest[]

  @@index([role])
  @@index([trustLevel])
  @@index([isSuspended])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([referralCode])
  @@index([universityId])
  @@schema("public")
}

model DeliveryBatch {
  id               String      @id @default(cuid())
  batchNumber      String      @unique
  buyerId          String
  riderId          String?
  universityId     String
  paymentReference String?
  referralPaid     Boolean     @default(false)
  status           BatchStatus @default(PENDING)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  buyer            User        @relation("BuyerBatches", fields: [buyerId], references: [id])
  rider            User?       @relation("RiderBatches", fields: [riderId], references: [id])
  orders           Order[]

  @@index([buyerId])
  @@index([riderId])
  @@index([status])
  @@index([universityId])
  @@schema("public")
}

model Product {
  id           String          @id @default(cuid())
  name         String
  description  String
  price        Float
  images       String[]
  category     String
  quantity     Int             @default(1)
  hostelName   String
  roomNumber   String
  landmark     String
  sellerId     String
  isActive     Boolean         @default(true)
  viewCount    Int             @default(0)
  avgRating    Float           @default(0)
  totalReviews Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  isDeleted    Boolean         @default(false)
  universityId String?
  subcategory     String?
  marketPrice     Float?          // Last confirmed campus sale price for this product type
  discountPercent Int?            // % cheaper than last confirmed sale price; null = not a deal
  isDeal          Boolean         @default(false)
  nameKey         String?         // normalised product name for market price matching
  variantKey      String?         // price-sensitive variant fingerprint (model/storage/ram/etc)
  conditionType   String?         // "NEW" | "USED" | "REFURBISHED"
  hasChangedParts Boolean         @default(false)
  isHot           Boolean         @default(false)
  hotReason       String?         // "VIEWS" | "DEAL" | "BOTH"
  hotScore        Int             @default(0)
  cartItems       CartItem[]
  orders       Order[]
  seller       User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  university   University?     @relation(fields: [universityId], references: [id])
  reviews      ProductReview[]
  reports      Report[]

  @@index([sellerId])
  @@index([category])
  @@index([subcategory])
  @@index([isActive])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([universityId])
  @@index([nameKey])
  @@index([variantKey])
  @@index([isHot])
  @@index([conditionType])
  @@index([nameKey, conditionType, hasChangedParts, variantKey])
  @@schema("public")
}

model MarketPrice {
  id              String   @id @default(cuid())
  nameKey         String
  variantKey      String?
  category        String
  condition       String
  hasChangedParts Boolean  @default(false)
  confirmedPrice  Float
  productId       String
  orderId         String   @unique
  recordedAt      DateTime @default(now())

  @@index([nameKey, condition, hasChangedParts])
  @@index([nameKey, condition, hasChangedParts, variantKey])
  @@index([category])
  @@index([recordedAt])
  @@schema("public")
}

model Order {
  id                 String          @id @default(cuid())
  orderNumber        String          @unique
  buyerId            String
  sellerId           String
  productId          String
  riderId            String?
  productPrice       Float
  deliveryFee        Float
  totalAmount        Float
  platformCommission Float           @default(0)
  quantity           Int             @default(1)
  deliveryHostel     String
  deliveryRoom       String
  deliveryLandmark   String
  deliveryPhone      String
  status             OrderStatus     @default(PENDING)
  orderedAt          DateTime        @default(now())
  riderAssignedAt    DateTime?
  pickedUpAt         DateTime?
  deliveredAt        DateTime?
  completedAt        DateTime?
  isPaid             Boolean         @default(false)
  isDisputed         Boolean         @default(false)
  disputeReason      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  orderNote          String?
  batchId            String?
  dispute            Dispute?
  batch              DeliveryBatch?  @relation(fields: [batchId], references: [id])
  buyer              User            @relation("BuyerOrders", fields: [buyerId], references: [id])
  product            Product         @relation(fields: [productId], references: [id])
  rider              User?           @relation("RiderDeliveries", fields: [riderId], references: [id])
  seller             User            @relation("SellerOrders", fields: [sellerId], references: [id])
  payment            Payment?
  productReviews     ProductReview[]
  referralReward     ReferralReward?
  reports            Report[]
  reviews            Review[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([riderId])
  @@index([batchId])
  @@index([status])
  @@index([createdAt])
  @@index([orderedAt])
  @@index([sellerId, status])
  @@index([riderId, status])
  @@schema("public")
}

model Review {
  id         String     @id @default(cuid())
  rating     Int
  comment    String?
  orderId    String
  reviewerId String
  revieweeId String
  type       ReviewType @default(SELLER)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewee   User       @relation("UserReviewsReceived", fields: [revieweeId], references: [id])
  reviewer   User       @relation("UserReviewsGiven", fields: [reviewerId], references: [id])

  @@unique([orderId, type, reviewerId])
  @@index([orderId])
  @@index([revieweeId])
  @@index([reviewerId])
  @@schema("public")
}

model ProductReview {
  id         String   @id @default(cuid())
  rating     Int
  comment    String
  orderId    String
  productId  String
  reviewerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ProductReviewsGiven", fields: [reviewerId], references: [id])

  @@unique([orderId, productId, reviewerId])
  @@index([orderId])
  @@index([productId])
  @@index([reviewerId])
  @@schema("public")
}

model OTP {
  id        String   @id @default(cuid())
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([email])
  @@schema("public")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  amount          Float
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?       @unique
  gatewayResponse Json?
  paidAt          DateTime?
  refundedAt      DateTime?
  refundAmount    Float?
  refundReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
  @@index([createdAt])
  @@schema("public")
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  type          TransactionType
  amount        Float
  description   String
  reference     String?
  balanceBefore Float
  balanceAfter  Float
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@schema("public")
}

model WithdrawalRequest {
  id          String           @id @default(cuid())
  userId      String
  amount      Float
  bankDetails Json
  status      WithdrawalStatus @default(PENDING)
  adminNotes  String?
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@schema("public")
}

model Report {
  id                String       @id @default(cuid())
  type              ReportType
  reason            ReportReason
  description       String
  evidence          String[]
  reporterId        String
  reportedUserId    String?
  reportedProductId String?
  reportedOrderId   String?
  status            ReportStatus @default(PENDING)
  adminNotes        String?
  resolvedAt        DateTime?
  resolvedBy        String?
  disputeId         String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  dispute           Dispute?     @relation(fields: [disputeId], references: [id])
  reportedOrder     Order?       @relation(fields: [reportedOrderId], references: [id])
  reportedProduct   Product?     @relation(fields: [reportedProductId], references: [id])
  reportedUser      User?        @relation("ReportsReceived", fields: [reportedUserId], references: [id])
  reporter          User         @relation("ReportsSubmitted", fields: [reporterId], references: [id])
  resolver          User?        @relation("ResolvedBy", fields: [resolvedBy], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([reportedProductId])
  @@index([status])
  @@schema("public")
}

model Dispute {
  id                   String           @id @default(cuid())
  orderId              String           @unique
  buyerId              String
  sellerId             String
  reason               String
  buyerEvidence        String[]
  sellerEvidence       String[]
  status               DisputeStatus    @default(OPEN)
  resolution           String?
  refundAmount         Float?
  resolvedAt           DateTime?
  resolvedBy           String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  pickupAddress        Json?
  resolutionPreference String?
  buyer                User             @relation("BuyerDisputes", fields: [buyerId], references: [id])
  order                Order            @relation(fields: [orderId], references: [id])
  resolver             User?            @relation("ResolvedBy", fields: [resolvedBy], references: [id])
  seller               User             @relation("SellerDisputes", fields: [sellerId], references: [id])
  messages             DisputeMessage[]
  report               Report?

  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@schema("public")
}

model DisputeMessage {
  id          String   @id @default(cuid())
  disputeId   String
  senderId    String
  senderType  String
  message     String
  attachments String[]
  createdAt   DateTime @default(now())
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@schema("public")
}

model Penalty {
  id          String        @id @default(cuid())
  userId      String
  action      PenaltyAction
  reason      String
  pointsAdded Int
  reportId    String?
  disputeId   String?
  bannedUntil DateTime?
  issuedBy    String?
  createdAt   DateTime      @default(now())
  issuer      User?         @relation("IssuedBy", fields: [issuedBy], references: [id])
  user        User          @relation("UserPenalties", fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@schema("public")
}

model Notification {
  id               String           @id @default(cuid())
  userId           String
  type             NotificationType
  title            String
  message          String
  orderId          String?
  productId        String?
  disputeId        String?
  reportId         String?
  reviewId         String?
  metadata         Json?
  isRead           Boolean          @default(false)
  readAt           DateTime?
  createdAt        DateTime         @default(now())
  referralRewardId String?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
  @@schema("public")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model SupportTicket {
  id         String                @id @default(cuid())
  name       String
  email      String
  message    String
  category   SupportTicketCategory @default(OTHER)
  userId     String?
  status     SupportTicketStatus   @default(OPEN)
  adminNotes String?
  resolvedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  user       User?                 @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@schema("public")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([userId])
  @@schema("public")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@schema("public")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
  @@schema("public")
}

model ReferralReward {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String
  orderId        String   @unique
  amount         Float
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id])
  referredUser   User     @relation("ReferredUserRewards", fields: [referredUserId], references: [id])
  referrer       User     @relation("ReferrerRewards", fields: [referrerId], references: [id])

  @@index([referrerId])
  @@index([referredUserId])
  @@index([createdAt])
  @@schema("public")
}

enum UserRole {
  BUYER
  SELLER
  RIDER
  ADMIN

  @@schema("public")
}

enum TrustLevel {
  BRONZE
  SILVER
  GOLD
  VERIFIED

  @@schema("public")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  RIDER_ASSIGNED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED

  @@schema("public")
}

enum BatchStatus {
  PENDING
  RIDER_ASSIGNED
  IN_PROGRESS
  COMPLETED

  @@schema("public")
}

enum TransactionType {
  CREDIT
  DEBIT
  ESCROW
  WITHDRAWAL
  REFERRAL_REWARD

  @@schema("public")
}

enum ReviewType {
  SELLER
  RIDER

  @@schema("public")
}

enum ReportType {
  PRODUCT
  SELLER
  RIDER
  BUYER

  @@schema("public")
}

enum ReportReason {
  FAKE_PRODUCT
  WRONG_DESCRIPTION
  POOR_QUALITY
  DELAYED_DELIVERY
  RUDE_BEHAVIOR
  SCAM
  INAPPROPRIATE_CONTENT
  PAYMENT_ISSUE
  OTHER

  @@schema("public")
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED

  @@schema("public")
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER_FAVOR
  RESOLVED_SELLER_FAVOR
  RESOLVED_COMPROMISE
  DISMISSED

  @@schema("public")
}

enum PenaltyAction {
  WARNING
  TEMP_BAN_1DAY
  TEMP_BAN_3DAYS
  TEMP_BAN_7DAYS
  TEMP_BAN_30DAYS
  PERMANENT_BAN
  TRUST_LEVEL_DOWNGRADE

  @@schema("public")
}

enum NotificationType {
  ORDER_PLACED
  ORDER_PROCESSING
  RIDER_ASSIGNED
  ORDER_PICKED_UP
  ORDER_ON_THE_WAY
  ORDER_DELIVERED
  ORDER_COMPLETED
  ORDER_DISPUTED
  ORDER_CANCELLED
  PRODUCT_REVIEWED
  SELLER_REVIEWED
  RIDER_REVIEWED
  DISPUTE_OPENED
  DISPUTE_MESSAGE
  DISPUTE_RESOLVED
  REPORT_SUBMITTED
  REPORT_RESOLVED
  PENALTY_ISSUED
  ACCOUNT_SUSPENDED
  ACCOUNT_UNSUSPENDED
  WITHDRAWAL_PROCESSED
  PAYMENT_RECEIVED
  REFERRAL_REWARD
  STOCK_ALERT

  @@schema("public")
}

enum SupportTicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED

  @@schema("public")
}

enum SupportTicketCategory {
  PAYMENT_ISSUE
  ORDER_PROBLEM
  ACCOUNT_ISSUE
  DISPUTE_HELP
  SELLER_ISSUE
  RIDER_ISSUE
  BUG_REPORT
  OTHER

  @@schema("public")
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED

  @@schema("public")
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  WALLET
  ESCROW

  @@schema("public")
}
